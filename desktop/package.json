{
  "name": "kenya-accounting-desktop",
  "private": true,
  "version": "1.1.2",
  "author": "Peter Wachanga <peter@example.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/wachanga173/KenyaBooks.git"
  },
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fortune-sheet/react": "latest",
    "better-sqlite3": "^11.8.1",
    "docx": "^9.0.0",
    "electron-updater": "^6.8.9",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.470.0",
    "luckyexcel": "^1.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.19",
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.28.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.2",
    "vite": "^8.0.16",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.kenyaaccounting.desktop",
    "productName": "Kenya Accounting",
    "publish": [
      {
        "provider": "github",
        "owner": "wachanga173",
        "repo": "KenyaBooks"
      }
    ],
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "extraResources": [
      {
        "from": "node_modules/better-sqlite3",
        "to": "node_modules/better-sqlite3"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}-${version}-Mac.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office",
      "artifactName": "${productName}-${version}-Linux.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "license": "build/license.txt",
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
